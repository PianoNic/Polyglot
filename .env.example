# Copy to .env and fill in. Every service in compose.prod.yml reads this file via
# env_file, so all configuration lives here — compose.prod.yml has no inline values.
# The keys are the exact names each container expects (the API binds the __-nested
# ones into its config), so do not rename them.
#
# A few values intentionally repeat because they cannot be composed here:
#   - the DB password appears in POSTGRES_PASSWORD and the connection string
#   - the RustFS keys appear in RUSTFS_* and the Backup__S3__* keys
#   - the Pocket ID URL appears in Oidc__Authority and APP_URL
#   - your public domain appears in several URLs
# Keep the repeated values in sync.

# ---- ASP.NET Core runtime (fixed; rarely changed) ----
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ---- Public origin (replace https://polyglot.example.com everywhere it appears) ----
Oidc__RedirectUri=https://polyglot.example.com/
Oidc__PostLogoutRedirectUri=https://polyglot.example.com
Cors__AllowedOrigins__0=https://polyglot.example.com

# ---- OIDC (Pocket ID) — Oidc__Authority and APP_URL are its public URL ----
Oidc__Authority=https://auth.polyglot.example.com
APP_URL=https://auth.polyglot.example.com
TRUST_PROXY=true
Oidc__ClientId=polyglot
Oidc__RequireHttpsMetadata=true
Oidc__Scope=openid profile email roles

# ---- Postgres (POSTGRES_PASSWORD must match the password in the connection string) ----
POSTGRES_PASSWORD=
POSTGRES_DB=polyglot
ConnectionStrings__PolyglotDatabase=Host=db;Port=5432;Database=polyglot;Username=postgres;Password=

# ---- OpenRouter ----
OpenRouter__ApiKey=
OpenRouter__DefaultModel=openai/gpt-5
Chat__TitleModel=mistralai/mistral-nemo

# ---- RustFS (S3-compatible storage; must match the Backup__S3__* keys below) ----
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=

# ---- Automated Postgres backups (pg_dump -> RustFS, daily) ----
Backup__Enabled=true
Backup__TimeOfDayUtc=03:00
Backup__RetentionCount=14
Backup__S3__Endpoint=http://rustfs:9000
Backup__S3__Bucket=polyglot-backups
Backup__S3__AccessKey=
Backup__S3__SecretKey=

# ---- Stripe billing (leave Stripe__SecretKey blank to keep billing disabled) ----
# Create the live Products/Prices in the Stripe dashboard, then map each Price id to
# the credits it grants below. Register the webhook at <public origin>/api/billing/webhook
# and paste the generated signing secret (whsec_...) into Stripe__WebhookSecret.
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=
Stripe__SuccessUrl=https://polyglot.example.com/billing?checkout=success
Stripe__CancelUrl=https://polyglot.example.com/billing?checkout=cancel
# Up to four products. Fill the slots you sell; leave the rest blank.
# Mode is "payment" (one-time credit pack) or "subscription".
Stripe__Products__0__PriceId=
Stripe__Products__0__Name=
Stripe__Products__0__Credits=0
Stripe__Products__0__Mode=payment
Stripe__Products__1__PriceId=
Stripe__Products__1__Name=
Stripe__Products__1__Credits=0
Stripe__Products__1__Mode=payment
Stripe__Products__2__PriceId=
Stripe__Products__2__Name=
Stripe__Products__2__Credits=0
Stripe__Products__2__Mode=payment
Stripe__Products__3__PriceId=
Stripe__Products__3__Name=
Stripe__Products__3__Credits=0
Stripe__Products__3__Mode=subscription
